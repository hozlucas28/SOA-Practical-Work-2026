{
	"service": "devcontainer",
	"dockerComposeFile": "compose.yaml",
	"workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
	"features": {
		"ghcr.io/devcontainers/features/docker-in-docker:2": {
			"version": "latest", // To match the host's Docker version.
			"dockerDashComposeVersion": "v2"
		}
	},
	"remoteUser": "root",
	"onCreateCommand": "chmod +x .devcontainer/setup-tools.sh",
	"postCreateCommand": ".devcontainer/setup-tools.sh",
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-vscode.cpptools-extension-pack",
				"platformio.platformio-ide",
				"Wokwi.wokwi-vscode",
				"docker.docker",
				"ms-azuretools.vscode-docker",
				"EditorConfig.EditorConfig",
				"bierner.markdown-checkbox",
				"bierner.markdown-preview-github-styles",
				"streetsidesoftware.code-spell-checker",
				"streetsidesoftware.code-spell-checker-spanish",
				"bierner.markdown-mermaid",
				"redhat.vscode-yaml",
				"tamasfe.even-better-toml"
			],
			"settings": {
				"telemetry.telemetryLevel": "off",
				"telemetry.feedback.enabled": false,
				"files.exclude": {
					"**/.DS_Store": true,
					"**/.git": false,
					"**/.hg": true,
					"**/.svn": true,
					"**/Thumbs.db": true
				},
				"search.exclude": {
					"**/.DS_Store": true,
					"**/.git": true,
					"**/.hg": true,
					"**/.svn": true,
					"**/Thumbs.db": true,
					"**/bower_components": true,
					"**/*.code-search": true
				},
				"C_Cpp.copilotHover": "disabled",
				"chat.agent.enabled": true,
				"chat.editing.confirmEditRequestRemoval": false,
				"docker.extension.enableComposeLanguageServer": true,
				"containers.images.sortBy": "Label",
				"containers.images.description": ["CreatedTime", "Size"],
				"containers.containers.label": "ContainerName",
				"containers.containers.sortBy": "Label",
				"containers.containers.description": [
					"ContainerName",
					"CreatedTime",
					"Image",
					"Ports",
					"Status"
				],
				"containers.networks.sortBy": "Label",
				"containers.networks.description": ["CreatedTime", "NetworkDriver"],
				"yaml.schemas": {
					"https://raw.githubusercontent.com/docker/vscode-extension/6a88caada42b57090df7ce91ec2a6561b422afe1/misc/empty.json": [
						"compose.yaml"
					]
				}
			}
		}
	}
}
